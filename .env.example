VITE_CESIUM_ION_TOKEN=
VITE_FLAT_TERRAIN=false
BLOB_READ_WRITE_TOKEN=
RANDO3D_ADMIN_PASSWORD=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Firebase — config web (publique, côté client). Sans ces valeurs, le portail
# retombe sur l'auth localStorage de prototype.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Google Drive Picker (public, cote client) pour importer des photos/videos
# choisies explicitement par l'utilisateur. APP_ID = numero de projet Google Cloud.
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_APP_ID=

# Firebase — clé de service (SECRÈTE, côté serveur uniquement). Extraite du JSON
# de compte de service. Garde les \n littéraux dans la clé privée entre guillemets.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative robuste à FIREBASE_PRIVATE_KEY : base64 de la clé PEM (ou du JSON
# de compte de service entier). Immunisé contre l'échappement des \n. Prioritaire
# si défini. Recommandé sur Vercel.
FIREBASE_PRIVATE_KEY_B64=

# Console admin : liste blanche d'uid Firebase autorisés (CSV). L'autorisation
# admin est revérifiée côté serveur sur chaque endpoint /api/admin/*.
ADMIN_UIDS=

# Mur d'accès temporaire « site en développement ». Si défini, le site entier est
# bloqué tant que ce mot de passe n'est pas saisi (vérifié côté serveur, jamais
# envoyé au client). Laisser vide = mur désactivé (site ouvert). À retirer au
# lancement public.
SITE_GATE_PASSWORD=
